#!/usr/bin/env ruby


lib_path = File.expand_path('../lib', __dir__)
$LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)

begin
  require 'connect_four'
rescue LoadError => e
  puts "Current Load PAth ($LOAD_PATH):"
  puts $LOAD_PATH
  puts "\nError: #{e.message}"
  exit 1
end

ConnectFour::Game.new.play
